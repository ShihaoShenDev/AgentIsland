<ci:SettingsPageBase xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:models="using:AgentIsland.Models"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                     mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
                     x:Class="AgentIsland.Views.SettingsPages.AgentIslandSettingsPage"
                     x:DataType="models:AgentIslandSettings">
    <Grid>
        <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8" Classes="settings-container animated-intro">
                <ci:IconText Glyph="&#xE713;" Text="智能体 MCP 服务设置" Margin="0 0 0 4" />

                <!-- 启用 MCP 服务器 -->
                <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE774;}"
                                     Header="启用 MCP 服务器"
                                     Description="允许智能体通过 Model Context Protocol 访问 ClassIsland 的课表和控制命令。">
                    <fa:SettingsExpander.Footer>
                        <ToggleSwitch IsChecked="{Binding IsEnabled}"/>
                    </fa:SettingsExpander.Footer>
                </fa:SettingsExpander>

                <!-- MCP 端口 -->
                <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE8BD;}"
                                     Header="服务监听端口"
                                     Description="指定 MCP 服务器监听的端口。">
                    <fa:SettingsExpander.Footer>
                        <NumericUpDown Value="{Binding Port}"
                                       Minimum="1"
                                       Maximum="65535"
                                       Increment="1"
                                       MinWidth="120"/>
                    </fa:SettingsExpander.Footer>
                </fa:SettingsExpander>

                <!-- 重启提示 -->
                <Border Background="#20FF9800"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ci:FluentIcon Glyph="&#xE7BA;"
                                       Foreground="#FFA726"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        <TextBlock Text="提示：修改启用状态或端口号后，需要重启 ClassIsland 才能生效。"
                                   Foreground="#FFA726"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ci:SettingsPageBase>
