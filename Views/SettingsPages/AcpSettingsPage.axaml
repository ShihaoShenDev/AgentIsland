<ci:SettingsPageBase xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:models="using:AgentIsland.Models"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                     mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
                     x:Class="AgentIsland.Views.SettingsPages.AcpSettingsPage"
                     x:DataType="models:AgentIslandSettings">
    <Grid>
        <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8" Classes="settings-container animated-intro">
                <ci:IconText Glyph="&#xE7C3;" Text="ACP 设置" Margin="0 0 0 4" />

                <Border Background="#20FF9800"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ci:FluentIcon Glyph="&#xE7BA;"
                                       Foreground="#FFA726"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        <TextBlock Text="ACP 功能当前不可用，将在后续版本中开放。"
                                   Foreground="#FFA726"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel IsEnabled="False" Opacity="0.5">
                    <!-- 启用 ACP 功能 -->
                    <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE7C3;}"
                                         Header="启用 ACP 功能"
                                         Description="启用 ACP 面板相关配置和 Agent 管理器入口。">
                        <fa:SettingsExpander.Footer>
                            <ToggleSwitch IsChecked="{Binding IsAcpEnabled}"/>
                        </fa:SettingsExpander.Footer>
                    </fa:SettingsExpander>

                    <!-- ACP Agent 管理器 -->
                    <Border Background="#14007ACC"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,4,0,0">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel>
                                    <TextBlock Text="ACP Agent 管理器"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding AcpAgentSummary}"
                                               Opacity="0.8"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="新增 Agent"
                                        Click="OnAddAcpAgent"/>
                            </Grid>

                            <TextBlock Text="{Binding AcpAgentEmptyStateText}"
                                       TextWrapping="Wrap"
                                       Opacity="0.75"/>

                            <ItemsControl ItemsSource="{Binding AcpAgents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AcpAgentProfile">
                                        <Border Background="#12000000"
                                                BorderBrush="#22000000"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding Name}"
                                                             Watermark="Agent 名称"/>
                                                    <Button Grid.Column="1"
                                                            Content="移除"
                                                            Tag="{Binding}"
                                                            Click="OnRemoveAcpAgent"/>
                                                </Grid>

                                                <TextBox Text="{Binding Command}"
                                                         Watermark="启动命令，如 python agent.py"/>

                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="16">
                                                    <CheckBox Content="启用"
                                                              IsChecked="{Binding IsEnabled}" />
                                                </StackPanel>

                                                <TextBlock Text="{Binding Status}"
                                                           Opacity="0.75"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ci:SettingsPageBase>
