<ci:SettingsPageBase xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                     xmlns:models="using:AgentIsland.Models"
                     x:Class="AgentIsland.Views.SettingsPages.AiTextSettingsPage"
                     x:DataType="models:AgentIslandSettings">
    <Grid>
        <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8" Classes="settings-container animated-intro">
                <ci:IconText Glyph="&#xE29B;" Text="AI 文字条目" Margin="0 0 0 4" />

                <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE9E4;}"
                                     Header="使用说明"
                                     Description="在此管理 AI 文字条目。每个条目有唯一 ID，组件通过 ID 绑定对应条目，AI 可通过 MCP 工具 set_component_text 按 ID 更新文字。"/>

                <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE00C;}"
                                     Header="添加条目"
                                     Description="创建一个新的 AI 文字条目。">
                    <fa:SettingsExpander.Footer>
                        <Button Content="添加" Click="OnAddEntry"/>
                    </fa:SettingsExpander.Footer>
                </fa:SettingsExpander>

                <ItemsControl ItemsSource="{Binding AiTextEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:AiTextEntry">
                            <fa:SettingsExpander Margin="0,0,0,4"
                                                 Description="{Binding Text}">
                                <fa:SettingsExpander.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="360"/>
                                        <Border Background="{DynamicResource SystemFillColorSubtleBackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding HasNoDescription}">
                                            <TextBlock Text="{Binding Id}"
                                                       FontSize="12"
                                                       Opacity="0.7"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </fa:SettingsExpander.Header>
                                <fa:SettingsExpander.Footer>
                                    <Button Content="删除" Tag="{Binding}" Click="OnDeleteEntry"/>
                                </fa:SettingsExpander.Footer>
                                <fa:SettingsExpanderItem Content="条目 ID">
                                    <fa:SettingsExpanderItem.Footer>
                                        <TextBox Text="{Binding Id}" Watermark="条目 ID" MinWidth="200"/>
                                    </fa:SettingsExpanderItem.Footer>
                                </fa:SettingsExpanderItem>
                                <fa:SettingsExpanderItem Content="备注">
                                    <fa:SettingsExpanderItem.Footer>
                                        <TextBox Text="{Binding Description}" Watermark="（可选）备注说明" MinWidth="200"/>
                                    </fa:SettingsExpanderItem.Footer>
                                </fa:SettingsExpanderItem>
                                <fa:SettingsExpanderItem Content="当前文字（由 AI 更新）">
                                    <fa:SettingsExpanderItem.Footer>
                                        <TextBox Text="{Binding Text}" Watermark="（AI 尚未设置）" MinWidth="240"/>
                                    </fa:SettingsExpanderItem.Footer>
                                </fa:SettingsExpanderItem>
                            </fa:SettingsExpander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="尚未创建任何条目。"
                           Opacity="0.4"
                           HorizontalAlignment="Center"
                           Margin="0,16"
                           IsVisible="{Binding !AiTextEntries.Count}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ci:SettingsPageBase>
