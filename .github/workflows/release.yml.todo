name: Release

on:
  schedule:
    - cron: "0 0 * * *"

  workflow_dispatch:

concurrency:
  group: release-${{ github.ref }}
  cancel-in-progress: false

jobs:
  release:
    runs-on: windows-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v7

      - name: Install .NET
        uses: actions/setup-dotnet@v5
        with:
          dotnet-version: 8.0.x

      - name: Configure GitHub CLI
        run: |
          echo ${{ secrets.BOT_TOKEN }} | gh auth login --with-token
          git config user.name "Shihao Shen"
          git config user.email "bot@shihaoshen.qzz.io"

      - name: Bump manifest version (4th digit +1) and commit
        id: bump
        shell: pwsh
        run: |
          $ErrorActionPreference = "Stop"
          $manifestPath = "AgentIsland/manifest.yml"
          if (-not (Test-Path $manifestPath)) {
            throw "manifest not found: $manifestPath"
          }

          $lines = Get-Content -Path $manifestPath -Encoding utf8
          $oldVersion = $null
          $newVersion = $null
          $newLines = foreach ($line in $lines) {
            if ($line -match '^\s*version:\s*(\d+)\.(\d+)\.(\d+)\.(\d+)\s*$') {
              $major = [int]$Matches[1]
              $minor = [int]$Matches[2]
              $patch = [int]$Matches[3]
              $build = [int]$Matches[4]
              $oldVersion = "$major.$minor.$patch.$build"
              $newVersion = "$major.$minor.$patch.$($build + 1)"
              ($line -replace 'version:\s*\d+\.\d+\.\d+\.\d+', "version: $newVersion")
            } else {
              $line
            }
          }

          if (-not $oldVersion -or -not $newVersion) {
            throw "Could not parse four-part version: from $manifestPath (expected 'version: x.y.z.w')"
          }

          $utf8NoBom = New-Object System.Text.UTF8Encoding $false
          [System.IO.File]::WriteAllLines((Resolve-Path $manifestPath), $newLines, $utf8NoBom)

          git add -- $manifestPath
          git commit -m "chore: Update to $newVersion"
          git push origin "HEAD:$($env:GITHUB_REF_NAME)"

          "version=$newVersion" | Out-File -FilePath $env:GITHUB_OUTPUT -Append -Encoding utf8
          "old_version=$oldVersion" | Out-File -FilePath $env:GITHUB_OUTPUT -Append -Encoding utf8
          "tag=v$newVersion" | Out-File -FilePath $env:GITHUB_OUTPUT -Append -Encoding utf8
          "bump_sha=$(git rev-parse HEAD)" | Out-File -FilePath $env:GITHUB_OUTPUT -Append -Encoding utf8

          Write-Host "Version bumped: $oldVersion -> $newVersion"

      - name: Build CIPX Package
        id: build
        run: dotnet publish -c Release -p:CreateCipx=true

      - name: Create GitHub Release
        id: release
        env:
          GH_TOKEN: ${{ secrets.BOT_TOKEN }}
        shell: pwsh
        run: |
          $ErrorActionPreference = "Stop"
          $version = "${{ steps.bump.outputs.version }}"
          $tag = "${{ steps.bump.outputs.tag }}"

          $cipxDir = "AgentIsland/cipx"
          if (-not (Test-Path $cipxDir)) {
            throw "CIPX output directory not found: $cipxDir"
          }

          $assets = @(Get-ChildItem -Path $cipxDir -File | ForEach-Object { $_.FullName })
          if ($assets.Count -eq 0) {
            throw "No files found in $cipxDir to upload"
          }

          Write-Host "Creating prerelease $tag with assets:"
          $assets | ForEach-Object { Write-Host "  $_" }

          # --fail-on-no-commits: fail if no commits since last release
          # --prerelease: mark as prerelease
          gh release create $tag @assets `
            --title $tag `
            --prerelease `
            --fail-on-no-commits `
            --generate-notes `
            --target $env:GITHUB_REF_NAME

      - name: Rollback version on failure
        if: failure() && steps.bump.outcome == 'success'
        env:
          GH_TOKEN: ${{ secrets.BOT_TOKEN }}
        shell: pwsh
        run: |
          $ErrorActionPreference = "Continue"
          $tag = "${{ steps.bump.outputs.tag }}"
          $oldVersion = "${{ steps.bump.outputs.old_version }}"
          $newVersion = "${{ steps.bump.outputs.version }}"
          $bumpSha = "${{ steps.bump.outputs.bump_sha }}"

          Write-Host "Release failed; rolling back version $newVersion -> $oldVersion"

          # Remove partial release/tag if create partially succeeded
          gh release delete $tag --yes --cleanup-tag 2>$null
          if ($LASTEXITCODE -ne 0) {
            git push origin ":refs/tags/$tag" 2>$null
          }

          # Revert the version-bump commit (safer than force-push on main)
          git fetch origin $env:GITHUB_REF_NAME
          git checkout -B $env:GITHUB_REF_NAME "origin/$($env:GITHUB_REF_NAME)"

          $head = git rev-parse HEAD
          if ($head -eq $bumpSha) {
            git revert --no-edit $bumpSha
            if ($LASTEXITCODE -ne 0) {
              Write-Host "git revert failed; restoring manifest.yml directly"
              $manifestPath = "AgentIsland/manifest.yml"
              $lines = Get-Content -Path $manifestPath -Encoding utf8
              $restored = foreach ($line in $lines) {
                if ($line -match '^\s*version:\s*') {
                  "version: $oldVersion"
                } else {
                  $line
                }
              }
              $utf8NoBom = New-Object System.Text.UTF8Encoding $false
              [System.IO.File]::WriteAllLines((Resolve-Path $manifestPath), $restored, $utf8NoBom)
              git add -- $manifestPath
              git commit -m "chore: rollback version to $oldVersion after failed release"
            }
            git push origin "HEAD:$($env:GITHUB_REF_NAME)"
            Write-Host "Version rollback pushed."
          } else {
            Write-Host "HEAD ($head) is not the bump commit ($bumpSha); attempting manifest restore."
            $manifestPath = "AgentIsland/manifest.yml"
            $content = Get-Content -Path $manifestPath -Raw -Encoding utf8
            if ($content -match "version:\s*$([regex]::Escape($newVersion))") {
              $content = $content -replace "version:\s*$([regex]::Escape($newVersion))", "version: $oldVersion"
              $utf8NoBom = New-Object System.Text.UTF8Encoding $false
              [System.IO.File]::WriteAllText((Resolve-Path $manifestPath), $content.TrimEnd() + "`n", $utf8NoBom)
              git add -- $manifestPath
              git status --porcelain
              if (git status --porcelain) {
                git commit -m "chore: rollback version to $oldVersion after failed release"
                git push origin "HEAD:$($env:GITHUB_REF_NAME)"
                Write-Host "Version rollback pushed."
              } else {
                Write-Host "Manifest already at old version; nothing to commit."
              }
            } else {
              Write-Host "Manifest does not contain $newVersion; skip file restore."
            }
          }
