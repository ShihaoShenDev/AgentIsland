<ci:ActionSettingsControlBase xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:ci="http://classisland.tech/schemas/xaml/core"
                              xmlns:models="using:AgentIsland.Models"
                              mc:Ignorable="d"
                              x:Class="AgentIsland.Views.ActionSettings.RunAcpActionSettingsControl"
                              x:Name="Root"
                              x:TypeArguments="models:RunAcpActionSettings">
    <StackPanel Spacing="10" Margin="8,12,8,0">
        <TextBlock Text="运行 ACP"
                   FontSize="16"
                   FontWeight="SemiBold"/>

        <Border Background="#20FF9800"
                CornerRadius="4"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ci:FluentIcon Glyph="&#xF430;"
                               Foreground="#FFA726"
                               FontSize="16"
                               VerticalAlignment="Center"/>
                <TextBlock Text="此功能当前不可用，将在后续版本中开放。"
                           Foreground="#FFA726"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel IsEnabled="False" Opacity="0.5">
            <TextBlock Text="选择一个已在 AgentIsland / ACP 设置中配置的 ACP Agent。自动化触发后，将启动该 Agent 进程。"
                       TextWrapping="Wrap"
                       Opacity="0.8"/>

            <TextBlock Text="{Binding EmptyStateText, ElementName=Root}"
                       TextWrapping="Wrap"
                       Opacity="0.75"/>

            <TextBlock Text="目标 Agent"/>
            <ComboBox ItemsSource="{Binding AgentNames, ElementName=Root}"
                      SelectedItem="{Binding Settings.AgentName, ElementName=Root, Mode=TwoWay}"/>

            <TextBlock Text="自定义 JSON 请求体（可选）"/>
            <TextBox Text="{Binding Settings.CustomPayload, ElementName=Root, Mode=TwoWay}"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap"
                     Watermark="请输入合法 JSON"/>

            <CheckBox Content="运行后显示通知"
                      IsChecked="{Binding Settings.ShowNotification, ElementName=Root, Mode=TwoWay}"/>
        </StackPanel>
    </StackPanel>
</ci:ActionSettingsControlBase>
