<ci:ComponentBase
    x:TypeArguments="local:AiTextComponentSettings"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AgentIsland.Models"
    xmlns:components="clr-namespace:AgentIsland.Components"
    x:Class="AgentIsland.Components.AiTextComponent">
    <Panel>
        <TextBlock
            Text="{Binding ResolvedText, RelativeSource={RelativeSource AncestorType=components:AiTextComponent}}"
            VerticalAlignment="Center" />
        <TextBlock
            x:Name="PlaceholderTextBlock"
            Text="{Binding PlaceholderText, RelativeSource={RelativeSource AncestorType=components:AiTextComponent}}"
            VerticalAlignment="Center"
            Opacity="0.4" />
    </Panel>
</ci:ComponentBase>
